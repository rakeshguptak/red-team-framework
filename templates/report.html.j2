<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Red Team Report — {{ report.target_name }}</title>
<style>
  :root {
    --bg: #0f1117;
    --surface: #1a1d2e;
    --border: #2d3154;
    --text: #e2e8f0;
    --muted: #8892b0;
    --critical: #ff4d4d;
    --high: #ff8c42;
    --medium: #ffd166;
    --low: #06d6a0;
    --pass: #4ade80;
    --accent: #7c3aed;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Segoe UI', system-ui, sans-serif; background: var(--bg); color: var(--text); padding: 2rem; }
  h1 { font-size: 1.8rem; font-weight: 700; margin-bottom: 0.25rem; }
  h2 { font-size: 1.2rem; font-weight: 600; margin: 2rem 0 1rem; color: var(--text); }
  .meta { color: var(--muted); font-size: 0.85rem; margin-bottom: 2rem; }
  .header { border-bottom: 1px solid var(--border); padding-bottom: 1.5rem; margin-bottom: 2rem; }
  .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
  .stat-card { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 1.25rem; text-align: center; }
  .stat-card .value { font-size: 2rem; font-weight: 700; }
  .stat-card .label { font-size: 0.75rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; margin-top: 0.25rem; }
  .pass-rate { color: {% if report.overall_pass_rate >= 0.8 %}var(--pass){% else %}var(--critical){% endif %}; }
  table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
  th { background: var(--surface); color: var(--muted); text-transform: uppercase; font-size: 0.7rem; letter-spacing: 0.07em; padding: 0.75rem 1rem; text-align: left; border-bottom: 2px solid var(--border); }
  td { padding: 0.75rem 1rem; border-bottom: 1px solid var(--border); vertical-align: top; }
  tr:hover td { background: rgba(124,58,237,0.05); }
  .badge { display: inline-block; padding: 0.2em 0.6em; border-radius: 4px; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; }
  .sev-critical { background: rgba(255,77,77,0.2); color: var(--critical); }
  .sev-high { background: rgba(255,140,66,0.2); color: var(--high); }
  .sev-medium { background: rgba(255,209,102,0.2); color: var(--medium); }
  .sev-low { background: rgba(6,214,160,0.2); color: var(--low); }
  .sev-pass { background: rgba(74,222,128,0.2); color: var(--pass); }
  .category-table { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; overflow: hidden; margin-bottom: 2rem; }
  .results-table { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
  .payload { font-family: monospace; font-size: 0.75rem; background: var(--bg); padding: 0.5rem; border-radius: 4px; max-width: 350px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: var(--muted); cursor: pointer; }
  .response-cell { max-width: 300px; font-size: 0.8rem; color: var(--muted); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .reasoning { font-size: 0.8rem; color: var(--muted); }
  .score-bar { display: flex; align-items: center; gap: 0.5rem; }
  .bar-bg { flex: 1; height: 6px; background: var(--border); border-radius: 3px; }
  .bar-fill { height: 100%; border-radius: 3px; }
  footer { margin-top: 3rem; padding-top: 1rem; border-top: 1px solid var(--border); font-size: 0.75rem; color: var(--muted); text-align: center; }
  details summary { cursor: pointer; color: var(--accent); font-size: 0.8rem; }
  details[open] summary { margin-bottom: 0.5rem; }
  pre { white-space: pre-wrap; word-break: break-all; font-size: 0.75rem; }
</style>
</head>
<body>

<div class="header">
  <h1>Red Team Scan Report</h1>
  <div class="meta">
    Target: <strong>{{ report.target_name }}</strong>
    {% if report.target_description %} — {{ report.target_description }}{% endif %}<br>
    Scan ID: {{ report.scan_id }}<br>
    Started: {{ report.started_at.strftime('%Y-%m-%d %H:%M:%S UTC') }} &nbsp;|&nbsp;
    Finished: {{ report.finished_at.strftime('%Y-%m-%d %H:%M:%S UTC') }}
  </div>
</div>

<div class="stats-grid">
  <div class="stat-card">
    <div class="value pass-rate">{{ "%.0f"|format(report.overall_pass_rate * 100) }}%</div>
    <div class="label">Pass Rate</div>
  </div>
  <div class="stat-card">
    <div class="value">{{ report.total_probes }}</div>
    <div class="label">Total Probes</div>
  </div>
  <div class="stat-card">
    <div class="value" style="color:var(--pass)">{{ report.total_passed }}</div>
    <div class="label">Passed</div>
  </div>
  <div class="stat-card">
    <div class="value" style="color:var(--critical)">{{ report.total_failed }}</div>
    <div class="label">Failed</div>
  </div>
  <div class="stat-card">
    <div class="value" style="color:var(--critical)">{{ critical_count }}</div>
    <div class="label">Critical</div>
  </div>
  <div class="stat-card">
    <div class="value" style="color:var(--high)">{{ high_count }}</div>
    <div class="label">High</div>
  </div>
</div>

<h2>Results by Category</h2>
<div class="category-table">
<table>
  <thead>
    <tr>
      <th>Category</th>
      <th>Probes</th>
      <th>Passed</th>
      <th>Failed</th>
      <th>Critical</th>
      <th>High</th>
      <th>Pass Rate</th>
    </tr>
  </thead>
  <tbody>
    {% for s in report.category_summaries | sort(attribute='pass_rate') %}
    <tr>
      <td>{{ s.category.value.replace('_', ' ').title() }}</td>
      <td>{{ s.total }}</td>
      <td style="color:var(--pass)">{{ s.passed }}</td>
      <td style="color:var(--critical)">{{ s.failed }}</td>
      <td style="color:var(--critical)">{{ s.critical }}</td>
      <td style="color:var(--high)">{{ s.high }}</td>
      <td>
        <div class="score-bar">
          <div class="bar-bg">
            <div class="bar-fill" style="width:{{ (s.pass_rate*100)|int }}%; background:{% if s.pass_rate >= 0.8 %}var(--pass){% else %}var(--critical){% endif %}"></div>
          </div>
          {{ "%.0f"|format(s.pass_rate * 100) }}%
        </div>
      </td>
    </tr>
    {% endfor %}
  </tbody>
</table>
</div>

<h2>All Probe Results</h2>
<div class="results-table">
<table>
  <thead>
    <tr>
      <th>Category</th>
      <th>Probe</th>
      <th>Severity</th>
      <th>Score</th>
      <th>Reasoning</th>
      <th>Payload / Response</th>
    </tr>
  </thead>
  <tbody>
    {% for r in report.results | sort(attribute='severity') %}
    <tr>
      <td>{{ r.category.value.replace('_', ' ').title() }}</td>
      <td style="font-size:0.8rem">{{ r.probe_name }}</td>
      <td><span class="badge sev-{{ r.severity.value }}">{{ r.severity.value }}</span></td>
      <td>
        <div class="score-bar">
          <div class="bar-bg">
            <div class="bar-fill" style="width:{{ (r.score*100)|int }}%; background:{% if r.score >= 0.7 %}var(--pass){% elif r.score >= 0.4 %}var(--medium){% else %}var(--critical){% endif %}"></div>
          </div>
          {{ "%.2f"|format(r.score) }}
        </div>
      </td>
      <td class="reasoning">{{ r.reasoning }}</td>
      <td>
        <details>
          <summary>View payload & response</summary>
          <strong>Payload:</strong>
          <pre>{{ r.payload | e }}</pre>
          <strong>Response:</strong>
          <pre>{{ r.response | e }}</pre>
        </details>
      </td>
    </tr>
    {% endfor %}
  </tbody>
</table>
</div>

<footer>
  Generated by Red Team Framework &nbsp;|&nbsp; {{ report.finished_at.strftime('%Y-%m-%d %H:%M UTC') }}
</footer>

</body>
</html>
